<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Cadastro de Alunos</title>
    <link rel="stylesheet" type="text/css" href="/style.css">
</head>
<body>

    <header style="padding: 20px; text-align: right;">
        <% if session[:admin] %>
            <span>Bem-vindo, <strong>Admin</strong>!</span>
            <a href="/logout" style="margin-left: 10px;">Sair</a>
        <% else %>
            <button id="openModal">Login</button>
        <% end %>
    </header>

    <main style="padding: 20px;">
        <h1>Lista de Alunos</h1>

        <table border="1" style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr>
                    <th>Nome</th>
                    <% if session[:admin] %> <th>Ações</th> <% end %>
                </tr>
            </thead>
            <tbody>
                <% @itens.each do |aluno| %>
                    <tr>
                        <td><%= aluno[:nome] %></td>
                        
                        <% if session[:admin] %>
                            <td>
                                <a href="/deletar/<%= aluno[:_id] %>" onclick="return confirm('Tem certeza?')">Excluir</a>
                            </td>
                        <% end %>
                    </tr>
                <% end %>
            </tbody>
        </table>

        <% if session[:admin] %>
            <div style="margin-top: 30px; padding: 20px; background: #f4f4f4;">
                <h3>Cadastrar Novo Aluno</h3>
                <form action="/inserir" method="post">
                    <input type="text" name="nome" placeholder="Nome do Aluno" required>
                    <button type="submit">Cadastrar</button>
                </form>
            </div>
        <% end %>
    </main>

    <dialog id="loginModal">
        <div class="modal-content">
            <span id="closeModal" style="cursor:pointer; float:right;">&times;</span>
            <h2>Login</h2>
        
            <% if session[:erro_login] %>
                <p style="color: red;"><%= session[:erro_login] %></p>
                <% session[:erro_login] = nil # Limpa a mensagem após mostrar %>
            <% end %>
            
            <form action="/login" method="post">
                <input type="text" name="username" placeholder="Username" required>
                <input type="password" name="password" placeholder="Password" required>
                <button type="submit">Enviar</button>
            </form>
        </div>
    </dialog>

    <script src="/script.js"></script>
</body>
</html>